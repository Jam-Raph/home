  border-right: none;
  margin-bottom: 0px !important;
}
.startup-wrapper {
  display: flex;
}
.startup-tabs {
  flex-direction: column;
  border: 1px solid #eee;
  border-left: none;
  padding-top: 25px;
  max-width: 230px;
  width: 100%;
}
.tab-btn {
  font-family: "Montserrat", sans-serif !important;
