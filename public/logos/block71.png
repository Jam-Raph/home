  }
  .programme-menu {
    max-width: 769px;
  }
  .gen-ai-25-hero {
    background-image: none !important;
  }
  .global-event-heading p {
    line-height: 1.7;
  }
  .programme-carousel .premium-carousel-inner a:nth-child(1) {
    left: 79%;
  }
  .programme-carousel .premium-carousel-inner a:nth-child(3) {
    left: 87%;
  }
  .sc-hero {
    background-image: none !important;
  }
  .ai-vc-partner .e-con-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: center !important;
  }
  .programme-card .thumb img {
    height: 270px !important;
  }
  .ai-communiity-partner .ai-faq-acccord .e-n-accordion-item-title-text {
    font-size: calc(1.265rem + 0.35vw);
  }
  .ai-journey-part::after {
    left: 4%;
  }
  .ai-journey-timeline::after {
    height: 83%;
    left: 15%;
  }
	    .aisa-journey-timeline::after {
        height: 79%;
        left: 15%;
    }
  .ds-timeline::after {
    height: 97% !important;
    left: 50% !important;
  }
  .ai-are-you-accordion p {
    line-height: 1.8 !important;
  }
  .ai-are-you-accordion a,
  .ai-are-you-accordion .e-n-accordion-item-title-text {
    font-size: calc(1.325rem + 0.9vw);
  }
  .ai-hero-heading h3,
  .ai-building-heading h2 {
    font-size: calc(1.625rem + 4.5vw);
  }
  .ai-why-choose-text p span,
  .ai-why-choose-text h2 {
    font-size: calc(1.425rem + 2.1vw);
  }
  .tech-banner-bg {
    background-image: none !important;
  }
  .incubation-container > div {
    padding: 0 80px;
    /* background: red; */
    max-width: 749px !important;
    width: 100%;
  }
  .footer-heading {
    max-width: 749px;
    width: 100%;
    font-size: calc(1.525rem + 3.3vw);
    margin: 0 auto;
  }
  .programme-grid {
    grid-template-columns: repeat(2, 1fr);
    padding: 25px;
  }
  .info-row {
    flex-direction: column;
    gap: 0px !important;
  }
  .info-row:has(.info-link) {
    gap: 33% !important;
    flex-direction: row;
    justify-content: space-between !important;
  }
}
@media (max-width: 900px) {
  .menu-item-has-children:after {
    top: 15px;
    transform: unset !important;
    right: 10px;
    pointer-events: none;
  }

  .menu-item-has-children.open::after {
    transform: rotate(180deg) !important;
  }

  #primary-navigation {
    overflow-y: scroll;
  }
  #primary-menu a {
    display: block !important;
  }
  .primary-nav__list li.has-submenu > .sub-menu {
    position: relative;
  }
  #primary-menu .menu-item-has-children .sub-menu {
    display: none !important;
  }

  #primary-menu .menu-item-has-children.open .sub-menu {
    display: block !important;
  }
  .ag-about-right {
    width: 70%;
  }
  .ag-hero {
    background-size: contain !important;
  }
  .primary-nav__list li.has-submenu .sub-menu {
    display: none;
  }

  .primary-nav__list li.has-submenu.open .sub-menu {
    display: block;
  }

  .primary-nav.open {
    transform: translateY(50px);
  }
  .primary-nav {
    min-height: 53vh;
  }
  .primary-nav .primary-nav__list li.menu-item {
    width: 100%;
    padding: 15px 15px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }
}
