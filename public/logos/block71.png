a:focus {
  outline: none !important;
  box-shadow: none !important;
}
.fs-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
    transition: 0.25s 
ease;
} 
.job-card-image-link img{
	max-height:none !important;
}


.tk-pagination span, .tk-pagination a {
    color:#fd7e08;
    text-decoration:none;
}
div.feedback-page::after{
	height:88%;
}
.tk-card a {
    height: 100% !important;
}
.roboto-font p,.roboto-font h3{
	font-family: Roboto, Arial, sans-serif !important;
}
.resource-detail a{
	cursor:pointer !important;
}
.resource-detail dd{
	margin:0px !important;
}
.roboto-font h3{
margin-bottom:10px;
}
.tk-card a img {
    height:200px !important;
}
.tk-card p{
font-size:14px;
}
div.tk-grid {

    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}
.fs-card-body{
	padding:20px;
}
.primary-nav__list {
	gap:15px;
}
.sb-post-cards-wrapper{
	gap:20px !important;
}
.inner-search-wrapper input {
  width: 100% !important;
}
.sort-options {
  right: unset !important;
  left: 0px !important;
}
.selected-filters-container {
  justify-content: center;
  opacity: 0.5;
}
.start-up-toolkiit .block_read_more {
  padding-bottom: 20px !important;
}
.block_read_more a {
  border-radius: 50px !important;
}
.selected-filters-container:hover {
  opacity: 1;
}
.back-btn-wrapper {
  max-width: 1200px !important;
  width: 100% !important;
  margin: 0 auto;
  box-shadow: 0 1px 0 0 #f0f0f0;
  min-height: 70px;
}
.cookie-popup button {
  background: #f1d600 !important;
  font-weight: 400 !important;
}
.primary-nav__list li a:focus {
  transform: translateY(0px) !important;
}
.cookie-popup {
  max-width: 300px;
  background: #222222 !important;
  bottom: 20px;
  right: 20px;
  padding: 18px 15px 30px 15px;
  border-radius: 0px !important;
}
.cookie-popup p {
  font-family: "Montserrat", sans-serif !important;
}
.all-jobs-link {
  padding: 20px 0;
  color: #000 !important;
}
.job-main-content {
  border: 1px solid #f0f0f0;
  border-right: none;
  padding: 20px 25px;
  margin-top: 0;
}
.startup-list,
.startup-filter-section {
  max-width: 1146px !important;
}
.job-header img {
  width: 100% !important;
  max-width: 100% !important;
}
.facebook .icon {
  background: #4267b2 !important;
}
.linkedin .icon {
  background: #0077b5 !important;
}
.twitter .icon {
  background: #1da1f2 !important;
}
.share-icon .icon {
  width: 17px;
  height: 17px;
}
.share-icon {
  /*      padding-left: 20px; */
  padding-right: 0;
  white-space: nowrap;
  font-family: Helvetica, sans-serif;
  font-size: 10px;
  display: inline-block;
  height: 16px;
  width: auto;
  line-height: 16px;
  text-decoration: none;
  color: black !important;
}
.pinterest .icon {
  background: #bd081c !important;
}
.site-header__inner .btn {
	color:#fff !important;
}

.tab-btn.active {
  border-bottom: none !important;
  border-right: 2px solid #ff7a00;
}
.job-tag {
  font-size: 10px !important;
  padding: 3px 8px !important;
  letter-spacing: 0.5px !important;
  line-height: 1;
  border: 1px solid #ddd !important;
  background: #eee !important;
  min-height: 0px;
  color: #333 !important;
}
.select2-results__option--selectable {
  cursor: pointer;
  font-size: 12.8px;
}
.job-section h3 {
  border: none !important;
}
.job-header h1 {
  margin-bottom: 5px !important;
  color: #575757 !important;
  line-height: 1.25em !important;
  font-weight: bold !important;
  font-size: 3rem !important;
}
.job-card-title a {
  color: #333 !important;
  text-decoration: none;
  font-family: "Funnel Display", sans-serif !important;
}
.job-card-title + p {
  font-size: 14px !important;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.email-job-text {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.line-height-nil p{
	line-height:1 !important;
}
.chip {
  background-color: rgba(55, 90, 107, 0.5) !important;
  color: #fff !important;
  text-transform: uppercase !important;
  border-radius: 0px !important;
  font-size: 10px !important;
}
.tab-content.active {
  width: 100%;
}
.tab-content {
  margin-top: 0px !important;
