<script>

  const el = document
  .querySelectorAll("#primary-menu .menu-item-has-children > a")

  console.log("ELe",el)

  el.forEach((link) => {
    link.addEventListener("click", function (e) {
      if (window.innerWidth <= 900) {
        e.preventDefault();

         const li = this.closest("li.menu-item-has-children");
        const submenu = li.querySelector("ul.sub-menu");
        const isOpen = submenu.style.display === "block"? true: false;


        // Close all others
        document
          .querySelectorAll("#primary-menu .menu-item-has-children.open")
          .forEach((item) => {
            if (item !== li) {
              item.classList.remove("open");
              
              item.querySelector(".sub-menu").style.display = "none";
             
            }
          });

        // Toggle current item open/close
        if (isOpen) {
          li.classList.remove("open");
          submenu.style.display = "none";
        } else {
          li.classList.add("open");
          submenu.style.display = "block";
        }
      }
    });
  });
</script>


