  }
  .primary-nav.open {
    transform: translateY(0px) !important;
    top: 95px !important;
  }
  .startup-logo-wrap {
    align-self: center;
  }
  .startup-logo-wrap img {
    width: 180px !important;
  }
	.us-market-acess-name::after{
	height:80%;
	
}
}

